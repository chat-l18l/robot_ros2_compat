root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{c,cc,cpp,cxx,h,hh,hpp,hxx}]
indent_size = 4
tab_width = 4

[{CMakeLists.txt,*.cmake,*.xml,*.toml,*.yaml,*.yml}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false
